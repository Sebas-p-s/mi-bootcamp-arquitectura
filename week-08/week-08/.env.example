# .env.example — copia a .env y rellena los valores reales
# NUNCA hagas commit del archivo .env original

# Base de datos
DATABASE_URL=postgres://rechum:CAMBIAR_ESTO@localhost:5432/rechum

# API
PORT=3000
NODE_ENV=development
APP_NAME=rechum-api

# JWT — genera con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_ESTO_MINIMO_32_CARACTERES_ALEATORIOS
JWT_EXPIRES_IN=15m

# bcrypt
BCRYPT_ROUNDS=12

# CORS
ALLOWED_ORIGINS=http://localhost:5173
